{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user preferences and physiological data.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "displayName": { "type": "string", "description": "User's display name" },
        "email": { "type": "string", "description": "User's email" },
        "gender": { "type": "string", "enum": ["Male", "Female", "Non-binary"] },
        "physiology": {
          "type": "object",
          "properties": {
            "lifeStage": { "type": "string", "enum": ["male", "puberty", "menopause", "adult", "senior"] },
            "sleepQuality": { "type": "number", "description": "0-100 scale" },
            "menstrualCycle": { "type": "boolean", "description": "Active cycle tracking" },
            "cycleDay": { "type": "number" }
          }
        },
        "preferences": {
          "type": "object",
          "properties": {
            "skinType": { "type": "string", "enum": ["dry", "oily", "combination", "normal", "sensitive"] },
            "allergies": { "type": "array", "items": { "type": "string" } },
            "location": { "type": "string", "description": "Default location or last known" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "EnvironmentalLog": {
      "title": "Environmental Log",
      "description": "Snapshot of environmental data at a specific time and location.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "User UID" },
        "timestamp": { "type": "string", "format": "date-time" },
        "location": { "type": "object" },
        "atmospheric": { "type": "object" },
        "optical": { "type": "object" },
        "biochemical": { "type": "object" },
        "geovisual": { "type": "object" }
      },
      "required": ["uid", "timestamp"]
    },
    "Recommendation": {
      "title": "AI Recommendation",
      "description": "Advice generated by Gemini based on environmental context.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "User UID" },
        "timestamp": { "type": "string", "format": "date-time" },
        "category": { "type": "string", "enum": ["clothing", "skincare", "health", "lifestyle"] },
        "content": { "type": "string" },
        "products": { "type": "array", "items": { "type": "object" } }
      },
      "required": ["uid", "timestamp", "content"]
    },
    "Feedback": {
      "title": "User Feedback",
      "description": "User's thermal comfort feedback.",
      "type": "object",
      "properties": {
        "timestamp": { "type": "string", "format": "date-time" },
        "recommendation": { "type": "string" },
        "feedback": { "type": "string", "enum": ["Too Cold", "Comfortable", "Too Hot"] },
        "env": { "type": "object" }
      },
      "required": ["timestamp", "feedback"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents."
    },
    "/users/{userId}/logs/{logId}": {
      "schema": "EnvironmentalLog",
      "description": "Environmental history for a user."
    },
    "/users/{userId}/recommendations/{recId}": {
      "schema": "Recommendation",
      "description": "AI recommendations for a user."
    },
    "/users/{userId}/feedback/{feedbackId}": {
      "schema": "Feedback",
      "description": "User thermal comfort feedback."
    }
  }
}
